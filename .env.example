# ===========================================
# Newsbridge Environment Configuration
# ===========================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# -------------------------------------------
# LLM / Translation (llama.cpp server)
# -------------------------------------------
# URL of the llama.cpp llama-server instance (host machine when running in Docker)
LLAMA_SERVER_URL=http://host.docker.internal:8000

# Model name loaded in llama-server (must match the model you started llama-server with)
LLM_MODEL=gemma:7b

# Max tokens per translation request
LLM_MAX_TOKENS=4096

# Temperature for LLM generation (lower = more deterministic)
LLM_TEMPERATURE=0.3

# -------------------------------------------
# RSS Polling
# -------------------------------------------
# How often to poll RSS feeds, in minutes
POLL_INTERVAL=30

# -------------------------------------------
# Database
# -------------------------------------------
# SQLite database path (relative to /app inside the container)
DATABASE_URL=sqlite+aiosqlite:///./data/newsbridge.db
